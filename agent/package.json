{
  "name": "somnus-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Somnus agent harness: Telegram gateway (long-polling, allowlisted) + Claude Agent SDK loop wired to brain-mcp.",
  "scripts": {
    "build": "tsc",
    "dev": "node --env-file=../.env --import tsx src/index.ts",
    "start": "node --env-file=../.env dist/index.js",
    "start:docker": "node dist/index.js",
    "cli": "node --env-file=../.env dist/cli.js",
    "backfill-edges": "node dist/backfill-edges.js",
    "test": "node --env-file-if-exists=../.env --import tsx --test src/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@anthropic-ai/sdk": "^0.104.1",
    "grammy": "^1.43.0",
    "pg": "^8.16.0",
    "pg-boss": "^12.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
