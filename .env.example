# Copy to .env and fill in. .env is gitignored.
DB_PASSWORD=change-me
# DB_PORT=5433  # override if 5432 is taken locally

# Agent (required to run agent/)
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=123456:ABC-...       # from @BotFather
TELEGRAM_ALLOWED_USER_ID=123456789      # your numeric id (ask @userinfobot)
DATABASE_URL=postgres://brain:${DB_PASSWORD}@127.0.0.1:5433/brain
# DAILY_SPEND_LIMIT_USD=10
# OPENAI_API_KEY=sk-...                 # optional: enables vector retrieval (text-embedding-3-small)
# Model tiers (both modular; chat also switchable live via /model in Telegram):
# CHAT_MODEL=claude-sonnet-4-6          # day-to-day chat (cheap, harness carries quality)
# DREAM_MODEL=claude-opus-4-8           # memory consolidation (errors compound — keep powerful)
